// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActivityCategory {
  id         String     @id @default(cuid())
  name       String     @unique
  custom     Boolean    @default(true)
  activities Activity[]
  createdAt  DateTime   @default(now())
}

model Activity {
  id          String           @id @default(cuid())
  title       String
  description String?
  client      String?
  status      String           @default("Pendente")
  categoryId  String
  category    ActivityCategory @relation(fields: [categoryId], references: [id])
  logs        ActivityLog[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  note       String
  createdAt  DateTime @default(now())
}

model FinanceCategory {
  id      String         @id @default(cuid())
  name    String         @unique
  kind    String         @default("A pagar")
  partner Boolean        @default(false)
  custom  Boolean        @default(true)
  entries FinanceEntry[]
  types   FinanceType[]  // ← novo: tipos vinculados à categoria
}

model FinanceType {
  id         String          @id @default(cuid())
  name       String
  kind       String          // "A pagar" | "A receber"
  categoryId String
  category   FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  active     Boolean         @default(true)
  entries    FinanceEntry[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([categoryId, kind, name])
}

model FinanceEntry {
  id                String          @id @default(cuid())
  title             String
  amount            Float
  dueDate           DateTime
  kind              String          @default("A pagar")
  category          FinanceCategory @relation(fields: [categoryId], references: [id])
  categoryId        String
  financeType       FinanceType?    @relation(fields: [financeTypeId], references: [id], onDelete: SetNull)
  financeTypeId     String?         // ← novo: opcional, só usado na Igreja
  partner           String          @default("")
  notes             String          @default("")
  recurring         Boolean         @default(false)
  confirmed         Boolean         @default(false)
  paid              Boolean         @default(false)
  paidAt            DateTime?
  generatedFromId   String?
  generatedFrom     FinanceEntry?   @relation("FinanceEntryRecurrence", fields: [generatedFromId], references: [id], onDelete: SetNull)
  generatedChildren FinanceEntry[]  @relation("FinanceEntryRecurrence")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}